from flask import Flask, render_template

app = Flask(__name__)

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/products')
def products():
    return 'Продукты'

@app.route('/contacts')
def contacts():
    return 'Контакты'

@app.route('/about')
def about():
    return 'О компании'

@app.route('/cart')
def cart():
    return 'Корзина'

if __name__ == "__main__":
    app.run()

