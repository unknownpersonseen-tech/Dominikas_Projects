import turtle

t = turtle.Turtle()

figure = input("What to draw a figure (square, circle, or triangle)?")
if figure == "square":
t.forward(100)
t.left(90)
t.forward(100)
t.left(90)
t.forward(100)
t.left(90)
t.forward(100)
t.left(90)
if figure == "circle":
t.circle(100)

if figure == "triangle":
t.forward(100)
t.left(120)
t.forward(100)
t.left(120)
t.forward(100)
t.left(120)
